{
  "name": "slot-engine",
  "version": "1.0.0",
  "description": "A generic, modern slot game engine",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@galacean/effects": "^2.9.3",
    "@galacean/engine": "^1.6.13",
    "@galacean/engine-lottie": "^1.5.1",
    "@galacean/engine-spine": "^4.2.8",
    "@galacean/engine-toolkit": "^1.6.0",
    "@galacean/tools": "^0.9.2",
    "fontfaceobserver": "^2.0.0"
  },
  "peerDependencies": {
    "fontfaceobserver": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "fontfaceobserver": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/fontfaceobserver": "^2.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
